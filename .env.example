# App
APP_NAME=eb3-microsite-chatbot
DEBUG=false

# Database (async for app; sync URL for migrations)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eb3chatbot
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/eb3chatbot

# LLM: OpenAI (dev) or vLLM (prod)
OPENAI_API_KEY=sk-...
# For vLLM, set base URL and model:
# OPENAI_BASE_URL=http://vllm:8000/v1
# LLM_MODEL=your-model-name
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=1024

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5

# S3
S3_BUCKET=eb3-documents
S3_REGION=us-east-1
# For local dev without S3, set USE_LOCAL_STORAGE=true (files under ./local_storage)
USE_LOCAL_STORAGE=true
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_ENDPOINT_URL=http://minio:9000
